<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>
        SkillHub Portal
    </display-name>

    <!--    Application Listener-->
    <listener>
        <listener-class>com.duskdev.skillhub.listener.AppContextListener</listener-class>
    </listener>

    <!--    Authentication Filter-->
    <filter>
        <filter-name>AuthenticationFilter</filter-name>
        <filter-class>
            com.duskdev.skillhub.filter.AuthenticationFilter
        </filter-class>
    </filter>
    <filter-mapping>
        <filter-name>AuthenticationFilter</filter-name>
        <url-pattern>/portal/*</url-pattern>
    </filter-mapping>

    <!--    Loin Servlet-->
    <servlet>
        <servlet-name>LogingServlrt</servlet-name>

        <servlet-class>com.duskdev.skillhub.servlet.LoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LogingServlrt</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>

    <!--    Logout Servlet-->
    <servlet>
        <servlet-name>LogoutServelt</servlet-name>

        <servlet-class>com.duskdev.skillhub.servlet.LogoutServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LogoutServelt</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>

    <!--    Dashboard Servlet-->
    <servlet>
        <servlet-name>DashboardServlet</servlet-name>
        <servlet-class>com.duskdev.skillhub.servlet.DashboardServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DashboardServlet</servlet-name>
        <url-pattern>/portal/dashboard</url-pattern>
    </servlet-mapping>

    <!--    Course Servlet-->
    <servlet>
        <servlet-name>CourseServlet</servlet-name>
        <servlet-class>com.duskdev.skillhub.servlet.CourseServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>CourseServlet</servlet-name>
        <url-pattern>/portal/courses</url-pattern>
    </servlet-mapping>

    <!--    Student Servlet-->
    <servlet>
        <servlet-name>StudentServlet</servlet-name>
        <servlet-class>com.duskdev.skillhub.servlet.StudentServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>StudentServlet</servlet-name>
        <url-pattern>/portal/students</url-pattern>
    </servlet-mapping>

    <!--    Trainer Servlet-->
    <servlet>
        <servlet-name>TranerServlet</servlet-name>
        <servlet-class>com.duskdev.skillhub.servlet.TrainerServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>TranerServlet</servlet-name>
        <url-pattern>/portal/trainers</url-pattern>
    </servlet-mapping>

<!--    Enrollment Servlet-->
    <servlet>
        <servlet-name>EnrollmentServlet</servlet-name>
        <servlet-class>com.duskdev.skillhub.servlet.EnrollmentServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>EnrollmentServlet</servlet-name>
        <url-pattern>/portal/enrollments</url-pattern>
    </servlet-mapping>
    
<!--    Attendance Servlet-->
    <servlet>
        <servlet-name>AttendanceServlet</servlet-name>
        <servlet-class>com.duskdev.skillhub.servlet.AttendanceServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AttendanceServlet</servlet-name>
        <url-pattern>/portal/attendance</url-pattern>
    </servlet-mapping>
    
    <!--    Session Configuration-->
    <session-config>
        <session-timeout>30</session-timeout>

        <cookie-config>
            <http-only>true</http-only>
        </cookie-config>
    </session-config>

    <!--    Login Page-->
    <welcome-file-list>
        <welcome-file>login</welcome-file>
    </welcome-file-list>

    <!--    Error Pages-->
    <error-page>
        <error-code>404</error-code>
        <location>/error.jsp</location>
    </error-page>

    <error-page>
        <error-code>500</error-code>
        <location>/error.jsp</location>
    </error-page>

</web-app>